# Base dev image for Go + Rust projects (deckpilot, control-plane-server)
# Not for Windows-native builds (ghostty WinUI3) — those use CI or setup-dev.ps1
FROM mcr.microsoft.com/devcontainers/base:ubuntu

# Zig (for non-Windows Zig work / cross-compilation experiments)
ARG ZIG_VERSION=0.14.1
RUN curl -fsSL "https://ziglang.org/download/${ZIG_VERSION}/zig-linux-x86_64-${ZIG_VERSION}.tar.xz" \
    | tar -xJ -C /opt \
    && ln -s /opt/zig-linux-x86_64-${ZIG_VERSION}/zig /usr/local/bin/zig

# Go and Rust are installed via devcontainer features (see devcontainer.json)
